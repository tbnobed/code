# Copy to .env before running docker compose up

# Required: password for the bundled Postgres
POSTGRES_PASSWORD=change-me

# Required: long random string for signing session cookies
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Ollama endpoint as seen from inside the container.
# Default reaches the Ollama server running on the Docker host (the DGX).
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Default model for new sessions
OLLAMA_MODEL=qwen3-coder-next
