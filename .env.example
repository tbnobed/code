# Copy to .env before running docker compose up

# Required: password for the bundled Postgres
POSTGRES_PASSWORD=change-me

# Required: long random string for signing session cookies
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Required: password for the seeded admin account (min 8 chars).
# Self-registration is disabled — this is the only login.
# Changing it and restarting the container rotates the admin password.
ADMIN_PASSWORD=change-me-min-8-chars

# Optional: admin username (default: admin)
# ADMIN_USERNAME=admin

# Ollama endpoint as seen from inside the container.
# Default reaches the Ollama server running on the Docker host (the DGX).
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional: GitHub push/pull sync for the agent.
# Create a fine-grained personal access token at
# https://github.com/settings/personal-access-tokens with "Contents:
# Read and write" (and "Administration: Read and write" if you want the
# agent to create new repos). The token stays in the container env only.
# GITHUB_TOKEN=github_pat_xxx
# GIT_USER_NAME=Your Name
# GIT_USER_EMAIL=you@example.com

# Default model for new sessions
OLLAMA_MODEL=qwen3-coder-next

# Prompt budget (tokens) ForgeOS trims chat history to fit. Keep in sync
# with the context window your Ollama server actually runs the model at.
# NOTE: OLLAMA_CONTEXT_LENGTH itself belongs on the HOST's Ollama service
# (sudo systemctl edit ollama -> Environment="OLLAMA_CONTEXT_LENGTH=32768",
# ideally with Environment="OLLAMA_KEEP_ALIVE=2h"), NOT in this file —
# Ollama's own default is only 4096 and it silently truncates the FRONT of
# over-long prompts (the agent's tool schemas die first).
# OLLAMA_NUM_CTX=32768

# Optional: "Send for review" second opinions from Claude.
# Feature stays hidden in the UI when unset.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: local image generation via Stable Diffusion.
# A1111: launch with --api --listen (its default 127.0.0.1 bind is
# unreachable from inside the container). ComfyUI: --listen 0.0.0.0 (:8188).
# IMAGE_GEN_URL=http://host.docker.internal:7860
